{
  "name": "@jackyzha0/quartz",
  "description": "🌱 publish your digital garden and notes as a website",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "author": "jackyzha0 <j.zhao2k19@gmail.com>",
